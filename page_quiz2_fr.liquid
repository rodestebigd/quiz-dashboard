window.addEventListener('popstate',function(){if(stepHistory.length>1){stepHistory.pop();goToStep(stepHistory[stepHistory.length-1],false);}});
function selectSingle(s,v){answers[s]=v;var el=document.querySelector('[data-step="'+s+'"]');el.querySelectorAll('.option-btn').forEach(function(b){b.classList.remove('selected');});event.currentTarget.classList.add('selected');setTimeout(function(){goToStep(s+1);},350);}
function toggleMulti(b,s,v){if(!multiSelections[s])multiSelections[s]=[];b.classList.toggle('selected');var i=multiSelections[s].indexOf(v);if(i>-1)multiSelections[s].splice(i,1);else multiSelections[s].push(v);answers[s]=multiSelections[s];}
function toggleImageOption(el,s,v){if(!multiSelections[s])multiSelections[s]=[];el.classList.toggle('selected');var i=multiSelections[s].indexOf(v);if(i>-1)multiSelections[s].splice(i,1);else multiSelections[s].push(v);answers[s]=multiSelections[s];}
function toggleZone(el,s,v){if(!multiSelections[s])multiSelections[s]=[];el.classList.toggle('selected');var i=multiSelections[s].indexOf(v);if(i>-1)multiSelections[s].splice(i,1);else multiSelections[s].push(v);answers[s]=multiSelections[s];}
function toggleSeverity(el,s,v){if(!multiSelections[s])multiSelections[s]=[];el.classList.toggle('selected');var i=multiSelections[s].indexOf(v);if(i>-1)multiSelections[s].splice(i,1);else multiSelections[s].push(v);answers[s]=multiSelections[s];}
function startLoading(s,d,nx){var sp=document.getElementById('spinner'+s),ck=document.getElementById('check'+s);if(sp)sp.style.display='block';if(ck){ck.classList.remove('visible');ck.style.display='none';}setTimeout(function(){if(sp)sp.style.display='none';if(ck)ck.style.display='flex';setTimeout(function(){if(ck)ck.classList.add('visible');},50);setTimeout(function(){goToStep(nx);},800);},d);}
function startLoadingRedirect(s,d){var sp=document.getElementById('spinner'+s),ck=document.getElementById('check'+s);if(sp)sp.style.display='block';if(ck){ck.classList.remove('visible');ck.style.display='none';}setTimeout(function(){if(sp)sp.style.display='none';if(ck)ck.style.display='flex';setTimeout(function(){if(ck)ck.classList.add('visible');},50);setTimeout(function(){window.location.href='https://juliecosmetique.fr/products/serum-liftant-julie';},800);},d);}
function startCircleRedirect(){var circle=document.getElementById('circleProgress'),txt=document.getElementById('circleText');if(!circle||!txt)return;var total=515,dur=3500,start=null;function ease(t){return t<0.5?2*t*t:1-Math.pow(-2*t+2,2)/2;}function frame(ts){if(!start)start=ts;var p=Math.min((ts-start)/dur,1);var e=ease(p);var pct=Math.round(e*100);circle.style.strokeDashoffset=total-(total*e);txt.textContent=pct+'%';if(p<1)requestAnimationFrame(frame);else setTimeout(function(){window.location.href='https://juliecosmetique.fr/products/serum-liftant-julie';},5000);}requestAnimationFrame(frame);}
function startProfileLoading(){var bar=document.getElementById('profileLoadingBar');var s1=document.getElementById('pls1'),s2=document.getElementById('pls2'),s3=document.getElementById('pls3');if(bar){setTimeout(function(){bar.style.width='100%';bar.style.transition='width 3.5s ease';},50);}if(s1)setTimeout(function(){s1.classList.add('visible');},400);if(s2)setTimeout(function(){s2.classList.add('visible');},1500);if(s3)setTimeout(function(){s3.classList.add('visible');},2700);setTimeout(function(){goToStep(12);},3500);}
var lvlTarget=82,lvlDuration=3500,lvlStarted=false;
function lvlEase(t){return 1-Math.pow(1-t,3);}
function lvlAnimate(){if(lvlStarted)return;var dot=document.getElementById('lvlIndicator'),tip=document.getElementById('lvlTooltip');if(!dot||!tip)return;lvlStarted=true;tip.style.opacity='1';var st=null;function frame(ts){if(!st)st=ts;var p=Math.min((ts-st)/lvlDuration,1),e=lvlEase(p),v=e*lvlTarget;dot.style.left=v+'%';tip.style.left=v+'%';if(p<1)requestAnimationFrame(frame);}requestAnimationFrame(frame);}
/* NEW REVIEWS CAROUSEL — 6 blocs, 3 par page desktop / 1 par page mobile */
var reviewsIdx=0,reviewsTotal=6,reviewsVisible=3,reviewsTouchX=0,reviewsTouchY=0;
function getReviewsVisibleCount(){return window.innerWidth>=768?3:1;}
function getReviewsPages(){return reviewsTotal-getReviewsVisibleCount()+1;}
function updateReviews(){
  var track=document.getElementById('reviewsTrack');if(!track)return;
  reviewsVisible=getReviewsVisibleCount();
  var pages=getReviewsPages();
  if(reviewsIdx>pages-1)reviewsIdx=pages-1;if(reviewsIdx<0)reviewsIdx=0;
  var blockW=100/reviewsVisible;
  track.style.transform='translateX(-'+(reviewsIdx*blockW)+'%)';
  var dotsC=document.getElementById('reviewsDots');
  if(dotsC){dotsC.innerHTML='';for(var i=0;i<pages;i++){var d=document.createElement('button');d.className='reviews-dot'+(i===reviewsIdx?' active':'');(function(n){d.addEventListener('click',function(){reviewsIdx=n;updateReviews();});})(i);dotsC.appendChild(d);}}
  var pb=document.getElementById('reviewsPrevBtn'),nb=document.getElementById('reviewsNextBtn');
  if(pb)pb.disabled=reviewsIdx===0;if(nb)nb.disabled=reviewsIdx>=pages-1;
}
function reviewsNext(){var pages=getReviewsPages();if(reviewsIdx<pages-1){reviewsIdx++;updateReviews();}}
function reviewsPrev(){if(reviewsIdx>0){reviewsIdx--;updateReviews();}}
/* Backward compat for inline HTML that may still call old carousel fns */
function carouselNext(){reviewsNext();}
function carouselPrev(){reviewsPrev();}
function carouselGoTo(i){reviewsIdx=i;updateReviews();}
var touchX=0;
window.addEventListener('resize',function(){updateReviews();});
var dpY,dpM,dpSel=null;
function initDP(){var n=new Date();dpY=n.getFullYear();dpM=n.getMonth();renderDP();}
function toggleDatePicker(){var d=document.getElementById('datepickerDropdown');if(d){d.classList.toggle('open');if(d.classList.contains('open'))initDP();}}
function dpPrevMonth(e){e.stopPropagation();dpM--;if(dpM<0){dpM=11;dpY--;}renderDP();}
function dpNextMonth(e){e.stopPropagation();dpM++;if(dpM>11){dpM=0;dpY++;}renderDP();}
function renderDP(){var ms=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];var t=document.getElementById('dpMonthYear');if(t)t.textContent=ms[dpM]+'    '+dpY;var dc=document.getElementById('dpDays');if(!dc)return;dc.innerHTML='';var fd=new Date(dpY,dpM,1).getDay();fd=fd===0?6:fd-1;var dim=new Date(dpY,dpM+1,0).getDate(),dipm=new Date(dpY,dpM,0).getDate(),today=new Date();for(var i=fd-1;i>=0;i--){var b=document.createElement('button');b.className='dp-day other-month';b.textContent=dipm-i;dc.appendChild(b);}for(var d=1;d<=dim;d++){var b=document.createElement('button');b.className='dp-day';b.textContent=d;if(d===today.getDate()&&dpM===today.getMonth()&&dpY===today.getFullYear())b.classList.add('today');if(dpSel&&d===dpSel.getDate()&&dpM===dpSel.getMonth()&&dpY===dpSel.getFullYear())b.classList.add('selected');(function(day){b.addEventListener('click',function(e){e.stopPropagation();dpSel=new Date(dpY,dpM,day);var f=String(day).padStart(2,'0')+'/'+String(dpM+1).padStart(2,'0')+'/'+dpY;document.getElementById('dateInput').value=f;answers[21]=f;renderDP();setTimeout(function(){document.getElementById('datepickerDropdown').classList.remove('open');},200);});})(d);dc.appendChild(b);}var tc=fd+dim,rem=(7-(tc%7))%7;for(var i=1;i<=rem;i++){var b=document.createElement('button');b.className='dp-day other-month';b.textContent=i;dc.appendChild(b);}}
function updateResultsPage(){var e=document.getElementById('eventName');if(e&&answers[20])e.textContent=answers[20];var t=new Date();t.setMonth(t.getMonth()+3);var d=document.getElementById('resultDate');if(d)d.textContent=String(t.getDate()).padStart(2,'0')+'/'+String(t.getMonth()+1).padStart(2,'0')+'/'+t.getFullYear();}
document.addEventListener('DOMContentLoaded',function(){updateProgressBar(1);history.replaceState({step:1},'','#step-1');updateReviews();var t=document.getElementById('reviewsCarousel');if(t){t.addEventListener('touchstart',function(e){touchX=e.touches[0].clientX;},{passive:true});t.addEventListener('touchend',function(e){var d=touchX-e.changedTouches[0].clientX;if(Math.abs(d)>50){if(d>0)reviewsNext();else reviewsPrev();}},{passive:true});}});
}
</script>
