/* Big green chevron */
.result-arrow-container { display: flex; align-items: center; justify-content: center; }
.result-chevron svg { width: 38px; height: 48px; display: block; }

/* Claim button */
.btn-claim {
  display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%;
  padding: 18px 32px; background: #0c233f; color: #fff; border: none; border-radius: 50px;
  font-size: 16px; font-weight: 700; cursor: pointer; letter-spacing: 0.5px; text-transform: uppercase;
  transition: all 0.2s ease; -webkit-tap-highlight-color: transparent;
}
.btn-claim:hover { background: #091b30; transform: translateY(-1px); }
