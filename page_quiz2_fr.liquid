/* INTERMEDIATE */
.intermediate-text { font-size: 15px; color: #555; text-align: center; line-height: 1.5; margin-bottom: 20px; }
.intermediate-image { width: 100%; max-width: 400px; margin: 0 auto 20px; display: block; border-radius: 12px; }
.community-image { width: 100%; max-width: 350px; margin: 20px auto 0; display: block; }

/* ============================================================
   RESULTS PAGE (etape 23) — Big cards + chevron + segmented bars
   ============================================================ */
.results-top-text { font-size: 13px; color: #555; text-align: center; margin-bottom: 4px; font-weight: 700; }
.results-headline { font-size: 24px; font-weight: 800; text-align: center; margin-bottom: 6px; line-height: 1.3; }
