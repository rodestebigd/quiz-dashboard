}
.severity-option {
  position: relative; background: #fff; border: 2px solid #dde1e6; border-radius: 14px;
  cursor: pointer; transition: all 0.2s ease; -webkit-tap-highlight-color: transparent;
  overflow: hidden; user-select: none;
}
