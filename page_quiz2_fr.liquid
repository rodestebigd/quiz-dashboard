.datepicker-dropdown { background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); padding: 16px; margin-bottom: 16px; display: none; }
.datepicker-dropdown.open { display: block; }
.dp-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
.dp-header-title { font-size: 16px; font-weight: 700; }
