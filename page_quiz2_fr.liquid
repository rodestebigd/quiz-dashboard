/* SUBTITLE STRONG — visible, not italic */
.quiz-subtitle-strong {
  font-size: 15px; color: #444; text-align: center; margin-bottom: 24px;
  font-weight: 600; font-style: normal;
}

/* ZONE GRID — 8 blocks, 4 cols desktop, 2 cols mobile */
.zone-grid-8 {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 20px;
}
.zone-option {
  position: relative; background: #fff; border: 2px solid #dde1e6; border-radius: 14px;
