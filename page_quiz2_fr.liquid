.btn-skip { display: block; text-align: center; margin-top: 16px; font-size: 14px; color: #888; cursor: pointer; text-decoration: none; font-weight: 500; }
.btn-skip:hover { color: #555; }

/* ============================================================
   CAROUSEL (etape 5) — FIXED
   ============================================================ */
/* CAROUSEL — simple show/hide (fonctionne mobile + desktop) */
.carousel-wrapper {
  position: relative;
  margin: 20px auto;
  max-width: 100%;
}
.carousel-viewport {
  position: relative;
  width: 100%;
}
.carousel-slide {
  display: none;
  width: 100%;
}
.carousel-slide.active {
  display: block;
}
.carousel-slide img {
  width: 100%;
  max-height: 400px;
  display: block;
  border-radius: 12px;
  object-fit: contain;
  margin: 0 auto;
}
.carousel-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-top: 16px;
}
.carousel-arrow {
  width: 44px;
  height: 44px;
  min-width: 44px;
  background: #0c233f;
  border: none;
  border-radius: 50%;
