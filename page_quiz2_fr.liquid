.shopify-section-group-footer-group,
header:not(.quiz-header),
.header:not(.quiz-header),
.header-wrapper,
#shopify-section-header,
.section-header,
.site-header,
nav.header__inline-menu,
footer, .footer, #shopify-section-footer, #footer, .site-footer,
.announcement-bar, #shopify-section-announcement-bar, .announcement-bar-section {
  display: none !important;
}

/* RESET */
* { margin: 0; padding: 0; box-sizing: border-box; }

.quiz-container {
