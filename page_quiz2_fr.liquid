  border: none; cursor: pointer; transition: background 0.3s ease;
  -webkit-tap-highlight-color: transparent;
}
.carousel-dot.active { background: #0c233f; }

/* LOADING */
.loading-screen { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 50vh; text-align: center; }
.loading-icon { width: 80px; height: 80px; position: relative; margin-bottom: 20px; }
.spinner-ring { width: 80px; height: 80px; border: 3px solid #ddd; border-top-color: #0c233f; border-radius: 50%; animation: spin 1s linear infinite; position: absolute; top: 0; left: 0; }
@keyframes spin { to { transform: rotate(360deg); } }
.check-icon { width: 80px; height: 80px; border: 3px solid #ccc; border-radius: 50%; display: flex; align-items: center; justify-content: center; opacity: 0; transform: scale(0.5); transition: all 0.4s ease; position: absolute; top: 0; left: 0; }
.check-icon.visible { opacity: 1; transform: scale(1); }
.check-icon svg { width: 36px; height: 36px; stroke: #999; stroke-width: 2.5; fill: none; }
.loading-text { font-size: 16px; color: #666; font-style: italic; }
.loading-headline { font-size: 24px; font-weight: 800; line-height: 1.3; margin-bottom: 16px; text-align: center; }
.loading-desc { font-size: 16px; color: #555; text-align: center; margin-bottom: 30px; line-height: 1.5; }
.loading-desc u { text-underline-offset: 3px; }

/* ============================================================
   LEVEL BAR (etape 13) — VISIBLE CURSOR
   ============================================================ */
.lvl-wrapper {
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  padding: 60px 30px 30px;
}
.lvl-bar-track {
  position: relative;
  width: 100%;
  height: 40px;
  display: flex;
  align-items: center;
}
.lvl-bar-fill {
  width: 100%;
  height: 18px;
  border-radius: 30px;
  background: linear-gradient(to right,
    #a8e4f0 0%, #7edbb5 18%, #b8e67a 30%, #d4e05a 42%,
    #f0d94e 52%, #f0c03e 60%, #f0a030 68%, #ef8030 75%,
    #ee5a3a 85%, #e63e3e 100%
  );
}
.lvl-dot {
  position: absolute;
  top: 50%;
  left: 0%;
  width: 34px;
  height: 34px;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2px 8px rgba(0,0,0,0.18), 0 0 0 2px rgba(0,0,0,0.04);
  transform: translate(-50%, -50%);
  z-index: 2;
  pointer-events: none;
}
.lvl-tip {
  position: absolute;
  top: -38px;
  left: 0%;
  transform: translateX(-50%);
  background: #3a3f47;
  color: #fff;
  font-size: 14px;
  font-weight: 500;
  padding: 7px 16px;
  border-radius: 8px;
  white-space: nowrap;
  z-index: 3;
  opacity: 0;
  letter-spacing: 0.2px;
  pointer-events: none;
}
.lvl-tip::after {
  content: '';
  position: absolute;
  bottom: -6px;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 7px solid transparent;
  border-right: 7px solid transparent;
  border-top: 7px solid #3a3f47;
}
.lvl-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12px;
  font-size: 15px;
  color: #777;
  font-weight: 400;
}
.lvl-labels span:last-child {
  color: #e64b4b;
  font-weight: 600;
}
@media (max-width: 600px) {
  .lvl-wrapper { padding: 50px 16px 20px; }
  .lvl-bar-track { height: 34px; }
  .lvl-bar-fill { height: 14px; }
  .lvl-dot { width: 28px; height: 28px; }
  .lvl-tip { top: -34px; font-size: 12px; padding: 6px 12px; border-radius: 7px; }
  .lvl-tip::after { bottom: -5px; border-left: 6px solid transparent; border-right: 6px solid transparent; border-top: 6px solid #3a3f47; }
  .lvl-labels { font-size: 13px; margin-top: 10px; }
}

/* PROFILE CARD */
.profile-card { background: #fff; border-radius: 16px; padding: 24px 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 20px; overflow: visible !important; }
